<Window x:Class="DecisionAnalysis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Decision Analysis" Height="680" Width="1100"
        Background="#FFFFFF" Foreground="#1A1A1A" FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>

        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="Background"       Value="#FFFFFF"/>
            <Setter Property="BorderBrush"      Value="#1A1A1A"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="CornerRadius"     Value="16"/>
            <Setter Property="Padding"          Value="16,6"/>
            <Setter Property="Margin"           Value="2,0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <Style x:Key="PillSelected" TargetType="Border" BasedOn="{StaticResource Pill}">
            <Setter Property="Background"  Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
        </Style>

        <Style x:Key="PopupBtn" TargetType="Button">
            <Setter Property="Background"              Value="White"/>
            <Setter Property="Foreground"              Value="#1A1A1A"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Padding"                 Value="12,9"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground"                  Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Sequence bars (left + right) ─────────────────────── -->
        <Grid Grid.Row="0" x:Name="SeqBarGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F5F5F5"
                    BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                <DockPanel>
                    <Button x:Name="BtnRunEv" DockPanel.Dock="Right"
                            Content="▶ Run EV" Click="BtnRunEv_Click"
                            Margin="8,0,8,0" Padding="12,5" FontSize="13"
                            Background="White" Foreground="#1A1A1A"
                            BorderBrush="#1A1A1A" BorderThickness="1"
                            VerticalAlignment="Center" Cursor="Hand"/>
                    <TextBlock x:Name="VocLabel" DockPanel.Dock="Right"
                               VerticalAlignment="Center" FontFamily="Segoe UI"
                               FontSize="13" Foreground="#1A1A1A"
                               Margin="16,0" Visibility="Collapsed"
                               Text="VOC = –"/>
<Button x:Name="BtnSave" DockPanel.Dock="Left"
                            Content="💾 Save" Click="BtnSave_Click"
                            Margin="8,0,0,0" Padding="12,5" FontSize="13"
                            Background="White" Foreground="#1A1A1A"
                            BorderBrush="#1A1A1A" BorderThickness="1"
                            VerticalAlignment="Center" Cursor="Hand"/>
                    <Button x:Name="BtnLoad" DockPanel.Dock="Left"
                            Content="📂 Load" Click="BtnLoad_Click"
                            Margin="4,0,0,0" Padding="12,5" FontSize="13"
                            Background="White" Foreground="#1A1A1A"
                            BorderBrush="#1A1A1A" BorderThickness="1"
                            VerticalAlignment="Center" Cursor="Hand"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="SequencePanel" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="24,0"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#F5F5F5"
                    BorderBrush="#CCCCCC" BorderThickness="1,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="RightSequencePanel" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="24,0"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Tree canvases (left + right) ─────────────────────── -->
        <Grid Grid.Row="1" x:Name="CanvasGrid" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>

            <Canvas x:Name="TreeCanvas" Grid.Column="0" Background="#FFFFFF"
                    SizeChanged="TreeCanvas_SizeChanged"/>
            <Canvas x:Name="RightTreeCanvas" Grid.Column="1" Background="Transparent"
                    SizeChanged="RightTreeCanvas_SizeChanged"/>
        </Grid>

        <!-- ── Node action popup ─────────────────────────────────── -->
        <Popup x:Name="NodePopup" StaysOpen="False" AllowsTransparency="True"
               Placement="MousePoint">
            <Border Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="8" Padding="4">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="16"
                                      Opacity="0.12" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel MinWidth="190">
                    <Button x:Name="BtnEditName"         Style="{StaticResource PopupBtn}"
                            Content="✎  Edit name"          Click="BtnEditName_Click"/>
                    <Button x:Name="BtnEditOutcomes"     Style="{StaticResource PopupBtn}"
                            Content="✎  Edit outcomes"      Click="BtnEditOutcomes_Click"/>
                    <Button x:Name="BtnToggleType"       Style="{StaticResource PopupBtn}"
                            Content="⇄  Toggle type"        Click="BtnToggleType_Click"/>
                    <Button x:Name="BtnEditConditionals" Style="{StaticResource PopupBtn}"
                            Content="⊞  Edit conditionals"  Click="BtnEditConditionals_Click"/>
                    <Separator Background="#CCCCCC" Margin="8,4"/>
                    <Button x:Name="BtnRemoveNode"       Style="{StaticResource PopupBtn}"
                            Content="✕  Remove node"        Click="BtnRemoveNode_Click"/>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</Window>
